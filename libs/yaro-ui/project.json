{
  "name": "yaro-ui",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/yaro-ui/src",
  "prefix": "yaro",
  "tags": ["scope:shared", "type:ui"],
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/yaro-ui/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/yaro-ui/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/yaro-ui/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/yaro-ui/jest.config.ts",
        "passWithNoTests": true
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/yaro-ui/**/*.ts", "libs/yaro-ui/**/*.html"]
      }
    }
  }
}
